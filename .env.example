# Example environment configuration for RAG Document Search

# Hostname and port of your Qdrant instance
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Name of the Qdrant collection to store document vectors
QDRANT_COLLECTION=rag_documents

# Embedding model to use (Hugging Face model hub id)
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# Generative model to use for answer generation
FLAN_MODEL=google/flan-t5-large

# API keys (optional depending on your embedding/generation models)
OPENAI_API_KEY=
